    <!-- BOST RAM MODAL -->
    <div class="bostram-modal" id="bostramModal" bis_skin_checked="1">
        <div class="bostram-header" bis_skin_checked="1">
            <h2>🚀 Tối ưu máy</h2>
        </div>
        <div class="bostram-content" bis_skin_checked="1">
            <div class="code-terminal" id="codeTerminal" bis_skin_checked="1">
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Initializing BOST RAM optimization...</span></div>
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Scanning system memory...</span></div>
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Clearing cache files...</span></div>
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Optimizing RAM allocation...</span></div>
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Freeing up memory blocks...</span></div>
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Applying performance boost...</span></div>
                <div class="code-line" bis_skin_checked="1"><span class="code-prompt">$</span> <span class="code-text">Finalizing optimization...</span></div>
            </div>
            <div class="bostram-success" id="bostramSuccess" style="display: none;" bis_skin_checked="1">
                <div class="success-icon" bis_skin_checked="1">✓</div>
                <div class="success-text" bis_skin_checked="1">BOST RAM thành công!</div>
                <button class="modal-btn success" id="closeBostramBtn">Đóng</button>
            </div>
        </div>
    </div>

    <div class="overlay" id="overlay" bis_skin_checked="1"></div>
    <div class="toggle-toast" id="toggleToast" bis_skin_checked="1"></div>
    <script>
// ==================== CẤU HÌNH (ĐÃ BYPASS LOGIN) ====================
const SERVER_URL = "https://raw.githubusercontent.com/AnhBinhTyler/AnhBinhTyler/refs/heads/main/SeverVipAppiOS";
const APP_TOKEN   = "APP_IF5EJ3IKKVA1JY5AKURW1FTVDX6XIFLT";

// MẶC ĐỊNH LUÔN LÀ TRUE ĐỂ KHÔNG BỊ VĂNG RA LOGIN
let isLoggedIn = true; 
let currentKey = "ADMIN-BYPASS";
let deviceId = localStorage.getItem("CONFIGMODE_DEVICE_ID") || "BYPASS-DEVICE";

// GIẢ LẬP SERVER LUÔN TRẢ VỀ THÀNH CÔNG ĐỂ CÁC HÀM KHÁC CHẠY ĐƯỢC
async function activateKey(key) {
    return { 
        success: true, 
        data: { valid: true, expiresAt: "31/12/2099 23:59", message: "Bypass Success" } 
    };
}

function showToggleToast(msg) {
  const toast = document.getElementById("toggleToast");
  if (!toast) return;
  toast.textContent = msg;
  toast.classList.add("active");
  clearTimeout(window.toastTimeout);
  window.toastTimeout = setTimeout(() => toast.classList.remove("active"), 2000);
}

function showPage(pageId) {
  document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
  const targetPage = document.getElementById(pageId);
  if (targetPage) targetPage.classList.add('active');
}

// ==================== DOM READY ====================
document.addEventListener("DOMContentLoaded", async () => {

  // 1. VÀO THẲNG MÀN HÌNH CHÍNH (BỎ QUA SPLASH VÀ LOGIN)
  showPage("mainScreen");
  showToggleToast("Hệ thống đã kích hoạt vĩnh viễn!");

  // 2. VẪN KHỞI TẠO HIỆU ỨNG LẤP LÁNH CHO ĐẸP
  initLoginEffects();

  // 3. SỬA NÚT BACK ĐỂ KHÔNG BỊ VĂNG RA NGOÀI
  document.querySelectorAll(".back-btn").forEach(btn => {
    btn.addEventListener("click", (e) => {
        e.preventDefault();
        showPage("mainScreen");
        showToggleToast("Bạn đang ở chế độ Admin");
    });
  });
  // ==================== SPLASH → LOGIN ====================
  document.getElementById("splashScreen").addEventListener("click", () => {
    showPage("loginScreen");
    initLoginEffects();
  });

  // ==================== LOGIN KEY ====================
  const keyInput = document.getElementById("keyInput");
  const loginBtn = document.getElementById("loginBtn");

  const handleLogin = async () => {
    const key = keyInput.value.trim();
    if (!key) {
      showToggleToast("Nhập key đi bro!");
      return;
    }

    loginBtn.disabled = true;
    loginBtn.textContent = "Đang kiểm tra key...";

    const result = await activateKey(key);

    if (result.success) {
      isLoggedIn = true;
      currentKey = key;
      localStorage.setItem("CONFIGMODE_KEY", key);
      keyInput.value = "";
      showPage("mainScreen");
      const daysLeft = getDaysLeft(result.data.expiresAt);
      showToggleToast(`Đăng nhập thành công! Còn ${daysLeft}`);
    } else {
      showToggleToast(result.data.message || "Key sai hoặc hết hạn!");
    }

    loginBtn.disabled = false;
    loginBtn.textContent = "LOGIN";
  };

  loginBtn.addEventListener("click", handleLogin);
  keyInput.addEventListener("keypress", e => e.key === "Enter" && handleLogin());

  // ==================== BACK BUTTON ====================
  document.querySelectorAll(".back-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      if (confirm("Thoát sẽ phải nhập lại key nha!")) {
        localStorage.removeItem("CONFIGMODE_KEY");
        isLoggedIn = false;
        showPage("splashScreen");
      }
    });
  });

    // ==================== TOGGLE BOST RAM RIÊNG (hiện popup tối ưu máy) ====================
  // Gắn event listener với capture phase để chạy trước
  document.addEventListener("click", async (e) => {
    const bootToggle = e.target.closest('.toggle-switch[data-toggle="boot"]');
    if (!bootToggle) return;
    
    e.stopPropagation(); // Ngăn event bubble lên
    e.stopImmediatePropagation(); // Ngăn các event listener khác chạy
      
      if (!isLoggedIn) {
        showToggleToast("Chưa nhập key!");
        return;
      }

      const check = await activateKey(currentKey);
      if (!check.success) {
        showToggleToast("Key hết hạn!");
        localStorage.removeItem("CONFIGMODE_KEY");
        isLoggedIn = false;
        showPage("loginScreen");
        return;
      }

      const toggle = bootToggle;
      const isActivating = !toggle.classList.contains("active");

      if (isActivating) {
        // Hiện popup BOST RAM
        document.getElementById("bostramModal").classList.add("active");
        document.getElementById("overlay").classList.add("active");
        
        // Reset và bắt đầu animation
        const terminal = document.getElementById("codeTerminal");
        const successDiv = document.getElementById("bostramSuccess");
        if (terminal) terminal.style.display = "block";
        if (successDiv) successDiv.style.display = "none";
        
        // Ẩn tất cả dòng code ban đầu
        if (terminal) {
          const codeLines = terminal.querySelectorAll(".code-line");
          codeLines.forEach(line => {
            line.style.opacity = "0";
            line.style.transform = "translateX(-20px)";
          });

          // Animation từng dòng code xuất hiện
          codeLines.forEach((line, index) => {
            setTimeout(() => {
              line.style.transition = "all 0.3s ease";
              line.style.opacity = "1";
              line.style.transform = "translateX(0)";
            }, index * 400);
          });
        }

        // Sau 3 giây hiện thông báo thành công
        setTimeout(() => {
          if (terminal) terminal.style.display = "none";
          if (successDiv) successDiv.style.display = "flex";
          toggle.classList.add("active");
          showToggleToast("Đã bật BOST RAM");
        }, 3000);
      } else {
        // Tắt BOST RAM
        toggle.classList.remove("active");
        const modal = document.getElementById("bostramModal");
        const overlay = document.getElementById("overlay");
        if (modal) modal.classList.remove("active");
        if (overlay) overlay.classList.remove("active");
        showToggleToast("Đã tắt BOST RAM");
      }
  }, true); // Capture phase

  // ==================== CÁC TOGGLE KHÁC (REG FILES, FIX RUNG) ====================
  document.querySelectorAll('.toggle-switch:not([data-toggle="CONFIGMODE"]):not([data-toggle="boot"])').forEach(toggle => {
    toggle.addEventListener("click", async () => {
      if (!isLoggedIn) return showToggleToast("Chưa nhập key!");

      const check = await activateKey(currentKey);
      if (!check.success) {
        showToggleToast("Key hết hạn!");
        localStorage.removeItem("CONFIGMODE_KEY");
        isLoggedIn = false;
        showPage("loginScreen");
        return;
      }

      toggle.classList.toggle("active");
      const label = toggle.closest(".toggle-item")?.querySelector(".toggle-label span:last-child")?.textContent || "";
      showToggleToast(toggle.classList.contains("active") ? `Đã bật ${label}` : `Đã tắt ${label}`);
    });
  });

  // ==================== TOGGLE CONFIGMODE RIÊNG (chỉ điều khiển toggle trên, không ảnh hưởng nút dưới) ====================
  document.querySelector('.toggle-switch[data-toggle="CONFIGMODE"]')?.addEventListener("click", async () => {
    if (!isLoggedIn) return showToggleToast("Chưa nhập key!");

    const check = await activateKey(currentKey);
    if (!check.success) {
      showToggleToast("Key hết hạn!");
      localStorage.removeItem("CONFIGMODE_KEY");
      isLoggedIn = false;
      showPage("loginScreen");
      return;
    }

    const toggle = document.querySelector('.toggle-switch[data-toggle="CONFIGMODE"]');
    toggle.classList.toggle("active");
    showToggleToast(toggle.classList.contains("active") ? "Đã bật CONFIGMODE" : "Đã tắt CONFIGMODE");
  });

  // ==================== NÚT ON / OFF DƯỚI RIÊNG BIỆT (chỉ điều khiển nút + modal, không ảnh hưởng toggle trên) ====================
  document.getElementById("onBtn")?.addEventListener("click", async () => {
    if (!isLoggedIn) return showToggleToast("Chưa nhập key!");

    const check = await activateKey(currentKey);
    if (!check.success) {
      showToggleToast("Key hết hạn!");
      localStorage.removeItem("CONFIGMODE_KEY");
      isLoggedIn = false;
      showPage("loginScreen");
      return;
    }

    // Chỉ bật nút + modal, KHÔNG đụng vào toggle trên
    document.getElementById("onBtn").classList.add("active");
    document.getElementById("offBtn").classList.remove("active");
    document.getElementById("successModal").classList.add("active");
    document.getElementById("overlay").classList.add("active");
    showToggleToast("Đã bật CONFIGMODE");
  });

  document.getElementById("offBtn")?.addEventListener("click", () => {
    document.getElementById("onBtn").classList.remove("active");
    document.getElementById("offBtn").classList.add("active");
    document.getElementById("successModal").classList.remove("active");
    document.getElementById("overlay").classList.remove("active");
    showToggleToast("Đã tắt CONFIGMODE");
  });

  document.getElementById("turnOffBtn")?.addEventListener("click", () => {
    document.getElementById("offBtn").click(); // Dùng lại hàm tắt ở trên
  });

  // ==================== INFO PANEL + SOCIAL ====================
  document.getElementById("hamburger").addEventListener("click", () => {
    document.getElementById("infoPanel").classList.add("active");
    document.getElementById("overlay").classList.add("active");
  });

  document.getElementById("closeInfo").addEventListener("click", () => {
    document.getElementById("infoPanel").classList.remove("active");
    document.getElementById("overlay").classList.remove("active");
  });

  document.getElementById("overlay").addEventListener("click", () => {
    document.getElementById("infoPanel").classList.remove("active");
    document.getElementById("successModal").classList.remove("active");
    document.getElementById("bostramModal").classList.remove("active");
    document.getElementById("overlay").classList.remove("active");
  });

  // ==================== BOST RAM MODAL ====================
  document.getElementById("closeBostramBtn")?.addEventListener("click", () => {
    document.getElementById("bostramModal").classList.remove("active");
    document.getElementById("overlay").classList.remove("active");
  });

  // Social buttons
  document.querySelector(".social-btn.zalo").addEventListener("click", () => alert("Zalo: 0385614724"));
  document.querySelector(".social-btn.facebook").addEventListener("click", () => 
    window.open("https://www.facebook.com/share/1GPvxT88gM/?mibextid=wwXIfr", "_blank")
  );

  document.querySelectorAll(".info-item").forEach(item => {
    const text = item.querySelector(".info-item-text").textContent;
    if (text === "FaceBook") item.addEventListener("click", () => window.open("https://www.facebook.com/share/1GPvxT88gM/?mibextid=wwXIfr", "_blank"));
    if (text === "TikTok") item.addEventListener("click", () => window.open("https://www.tiktok.com/@tiendayv2", "_blank"));
    if (text === "Panel made by TBR") item.addEventListener("click", () => window.open("https://zalo.me/0385614724", "_blank"));
  });

  document.querySelector(".update-btn").addEventListener("click", () => {
    showToggleToast("Đã là bản VIP mới nhất 2026!");
  });

  // Logo click về splash
  document.querySelectorAll("#splashLogo, #loginLogo, #mainLogo").forEach(logo => {
    logo.style.cursor = "pointer";
    logo.addEventListener("click", () => showPage("splashScreen"));
  });

  // ==================== HIỆU ỨNG LOGIN SCREEN ====================
  function initLoginEffects() {
    createBackgroundSparkles();
    createParticles();
    addTitleSparkles();
    addLogoSparkles();
    addButtonSparkles();
    addInputSparkles();
    addSocialSparkles();
    addMagicCursor();

    document.querySelectorAll('.login-logo-placeholder img, .login-header h1').forEach(el => {
      el.classList.add('enhanced-glow');
    });
  }

  function createBackgroundSparkles() {
    let container = document.querySelector('.sparkle-container');
    if (container) return;
    
    container = document.createElement('div');
    container.className = 'sparkle-container';
    document.body.appendChild(container);

    for (let i = 0; i < 20; i++) {
        const sparkle = document.createElement('div');
        sparkle.className = 'sparkle';
        sparkle.style.left = `${Math.random() * 100}%`;
        sparkle.style.top = `${Math.random() * 100}%`;
        sparkle.style.animationDelay = `${Math.random() * 5}s`;
        container.appendChild(sparkle);
    }
  }

  function createParticles() {
    let container = document.querySelector('.particles');
    if (container) return;
    
    container = document.createElement('div');
    container.className = 'particles';
    document.body.appendChild(container);

    for (let i = 0; i < 50; i++) {
        const particle = document.createElement('div');
        particle.className = 'particle';
        particle.style.left = `${Math.random() * 100}%`;
        particle.style.top = `${Math.random() * 100}%`;
        particle.style.width = `${Math.random() * 3 + 1}px`;
        particle.style.height = `${Math.random() * 3 + 1}px`;
        particle.style.animationDuration = `${Math.random() * 8 + 4}s`;
        container.appendChild(particle);
    }
  }

  function addTitleSparkles() {
    const title = document.querySelector('.login-header h1');
    if (!title || title.querySelector('.title-sparkle')) return;
    
    for (let i = 0; i < 8; i++) {
        const sparkle = document.createElement('div');
        sparkle.className = 'title-sparkle';
        sparkle.style.left = `${Math.random() * 100}%`;
        sparkle.style.animationDelay = `${Math.random() * 2}s`;
        title.appendChild(sparkle);
    }
  }

  function addLogoSparkles() {
    const logo = document.querySelector('.login-logo-placeholder');
    if (!logo || logo.querySelector('.logo-sparkle')) return;
    
    const positions = [
        { top: '0%', left: '0%' },
        { top: '0%', left: '100%' },
        { top: '100%', left: '0%' },
        { top: '100%', left: '100%' }
    ];
    
    positions.forEach((pos, i) => {
        const sparkle = document.createElement('div');
        sparkle.className = 'logo-sparkle';
        sparkle.style.top = pos.top;
        sparkle.style.left = pos.left;
        sparkle.style.animationDelay = `${i * 0.5}s`;
        logo.appendChild(sparkle);
    });
  }

  function addButtonSparkles() {
    const button = document.querySelector('.login-btn');
    if (!button || button.querySelector('.btn-sparkle')) return;
    
    const sparkle = document.createElement('div');
    sparkle.className = 'btn-sparkle';
    button.appendChild(sparkle);
  }

  function addInputSparkles() {
    const input = document.querySelector('.key-input');
    if (!input || input.querySelector('.input-sparkle')) return;
    
    const sparkle = document.createElement('div');
    sparkle.className = 'input-sparkle';
    input.appendChild(sparkle);
  }

  function addSocialSparkles() {
    const socialButtons = document.querySelectorAll('.social-btn');
    socialButtons.forEach(btn => {
        if (btn.querySelector('.social-sparkle')) return;
        const sparkle = document.createElement('div');
        sparkle.className = 'social-sparkle';
        btn.appendChild(sparkle);
    });
  }

  function addMagicCursor() {
    if (window.magicCursorAdded) return;
    window.magicCursorAdded = true;
    
    document.addEventListener('mousemove', (e) => {
        if (Math.random() > 0.7) {
            const cursor = document.createElement('div');
            cursor.className = 'magic-cursor';
            cursor.style.left = `${e.clientX - 10}px`;
            cursor.style.top = `${e.clientY - 10}px`;
            document.body.appendChild(cursor);
            setTimeout(() => cursor.remove(), 500);
        }
    });
  }
});
</script>
    <script>
// Đoạn này thay thế hoàn toàn đoạn code cũ của bạn
document.getElementById('openFreeFireBtn')?.addEventListener('click', () => {
    // 1. Đóng popup trước (giữ nguyên hiệu ứng của bạn)
    const modal   = document.getElementById('successModal');
    const overlay = document.getElementById('overlay');

    if (modal)   modal.classList.remove('active');
    if (overlay) overlay.classList.remove('active');

    // 2. Lấy phiên bản đã chọn
    const selectedVersion = localStorage.getItem('CONFIGMODE_FREEFIRE_VERSION') || 'freefire';
    
    // 3. Đợi popup đóng xong rồi mới mở Free Fire (rất quan trọng để không bị Safari chặn)
    setTimeout(() => {
        openFreeFireApp(selectedVersion);
    }, 400); // 400ms là ngọt nhất – bạn có thể giảm xuống 300 nếu muốn nhanh hơn
});

// Xử lý chọn phiên bản Free Fire
document.querySelectorAll('.freefire-option').forEach(btn => {
    btn.addEventListener('click', function() {
        // Xóa active khỏi tất cả
        document.querySelectorAll('.freefire-option').forEach(b => b.classList.remove('active'));
        // Thêm active vào nút được click
        this.classList.add('active');
        // Lưu lựa chọn
        const version = this.getAttribute('data-version');
        localStorage.setItem('CONFIGMODE_FREEFIRE_VERSION', version);
    });
});

// Khôi phục lựa chọn đã lưu khi mở modal
document.getElementById('onBtn')?.addEventListener('click', () => {
    const savedVersion = localStorage.getItem('CONFIGMODE_FREEFIRE_VERSION') || 'freefire';
    document.querySelectorAll('.freefire-option').forEach(btn => {
        btn.classList.remove('active');
        if (btn.getAttribute('data-version') === savedVersion) {
            btn.classList.add('active');
        }
    });
});

// Hàm mở Free Fire cực mạnh – hoạt động ngon lành cả trong Web Clip
function openFreeFireApp(version = 'freefire') {
    // URL scheme cho từng phiên bản
    const schemes = {
        'freefire': 'freefireth://',
        'freefiremax': 'freefiremax://'
    };
    
    const scheme = schemes[version] || schemes['freefire'];
    const appStore = version === 'freefiremax' 
        ? "https://apps.apple.com/vn/app/garena-free-fire-max/id1584092163"
        : "https://apps.apple.com/vn/app/garena-free-fire/id1300146617";

    // Cách 1: Dùng iframe ẩn (cách mạnh nhất trên iOS 15–18, kể cả trong Web Clip)
    const iframe = document.createElement("iframe");
    iframe.style.display = "none";
    iframe.src = scheme;
    document.body.appendChild(iframe);

    // Cách 2: Dự phòng bằng location.href (vẫn cần để chắc ăn)
    window.location.href = scheme;
}
</script>
<script>
// CHỈ CHẶN XEM SOURCE CODE (Ctrl+U + F12 + Chuột phải View Source)
// Các hành động khác vẫn bình thường – form admin không bị ảnh hưởng

// Cửa hậu cho bạn (tuỳ chọn): thêm ?admin hoặc ?123 vào URL là tắt hết chặn
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.has('admin') || urlParams.has('123')) return;

// 1. Chặn Ctrl+U / Cmd+U
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key.toUpperCase() === 'U') {
    e.preventDefault();
    e.stopPropagation();
  }
}, true);

// 2. Chặn F12 (mở DevTools)
document.addEventListener('keydown', e => {
  if (e.key === 'F12' || e.keyCode === 123) {
    e.preventDefault();
    e.stopPropagation();
  }
}, true);

// 3. Chặn chuột phải → chỉ chặn menu "View Page Source", không chặn chọn text hay input
document.addEventListener('contextmenu', e => {
  // Nếu người dùng click chuột phải vào input, textarea, button → cho phép menu bình thường
  const tag = e.target.tagName.toUpperCase();
  if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON' || tag === 'SELECT') {
    return; // không chặn
  }
  e.preventDefault();
}, true);

</script>

<span id="PING_IFRAME_FORM_DETECTION" style="display: none;"></span></body></html>
